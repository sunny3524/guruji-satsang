// ─── Firestore Security Rules ─────────────────────────────────────────────────
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null &&
             userDoc.data.role == 'admin';
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
                      (request.auth.uid == uid &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                      || isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ── Satsangs collection ───────────────────────────────────────────────────
    match /satsangs/{satsangId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
                      resource.data.organizerUid == request.auth.uid
                      || isAdmin()
                      || (
                        request.resource.data.diff(resource.data)
                          .affectedKeys().hasOnly(['attendeeCount', 'updatedAt']) &&
                        (
                          request.resource.data.attendeeCount == resource.data.attendeeCount + 1 ||
                          request.resource.data.attendeeCount == resource.data.attendeeCount - 1
                        )
                      )
                    );
      allow delete: if request.auth != null && (
                      resource.data.organizerUid == request.auth.uid || isAdmin()
                    );

      // ── Attendees subcollection (Direct Document Access / Single Satsang View) ───
      match /attendees/{userId} {
        allow read: if request.auth != null && (
                      resource.id == request.auth.uid ||
                      get(/databases/$(database)/documents/satsangs/$(satsangId)).data.organizerUid == request.auth.uid ||
                      isAdmin()
                    );
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && (
                      request.auth.uid == userId || isAdmin()
                    );
      }
    }

    // ── Collection Group Rules for Dashboard Queries ───────────────────────────
    // This allows collectionGroup('attendees') property queries to match safely
    match /{path=**}/attendees/{userId} {
      allow read: if request.auth != null && (resource.data.userUid == request.auth.uid || isAdmin());
    }
  }
}